{
  "name": "pi-generative-ui",
  "version": "0.2.1",
  "description": "Generative UI for pi — render interactive HTML/SVG widgets in Glimpse-rendered windows across macOS and Linux/WSL",
  "type": "commonjs",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      ".pi/extensions/generative-ui"
    ]
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "format": "prettier --write README.md package.json .pi/extensions/generative-ui/*.ts",
    "format:check": "prettier --check README.md package.json .pi/extensions/generative-ui/*.ts",
    "lint": "npm run typecheck && npm run format:check",
    "test": "npm run lint"
  },
  "dependencies": {
    "glimpseui": "^0.6.2"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "author": "michaelliv",
  "license": "MIT"
}
